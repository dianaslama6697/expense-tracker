generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExpenseSource {
  manual
  ocr
}

enum ReceiptStatus {
  pending
  done
  failed
}

enum BudgetPeriod {
  monthly
  weekly
}

model User {
  id             String    @id @default(uuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  image          String?
  avatarUrl      String?   @map("avatar_url")
  password       String?
  currency       String    @default("IDR")
  provider       String?
  providerId     String?   @map("provider_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  categories Category[]
  expenses   Expense[]
  receipts   Receipt[]
  budgets    Budget[]
  pockets    Pocket[]
  tags       Tag[]
  accounts   Account[]
  sessions   Session[]
  splitBills SplitBill[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  icon        String?
  color       String?
  isDefault   Boolean  @default(false) @map("is_default")
  budgetLimit Decimal? @map("budget_limit")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
  budgets  Budget[]
  pockets  PocketCategory[]

  @@map("categories")
}

model Expense {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  categoryId  String        @map("category_id")
  receiptId   String?       @map("receipt_id")
  amount      Decimal
  currency    String        @default("IDR")
  merchant    String?
  description String?
  expenseDate DateTime      @map("expense_date")
  source      ExpenseSource @default(manual)
  createdAt   DateTime      @default(now()) @map("created_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category     @relation(fields: [categoryId], references: [id])
  receipt  Receipt?     @relation(fields: [receiptId], references: [id])
  tags     ExpenseTag[]

  @@map("expenses")
}

model Receipt {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  imageUrl    String        @map("image_url")
  imageKey    String        @map("image_key")
  status      ReceiptStatus @default(pending)
  rawText     String?       @map("raw_text")
  aiData      Json?         @map("ai_data")
  confidence  Decimal?
  processedAt DateTime?     @map("processed_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@map("receipts")
}

model Budget {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  categoryId String       @map("category_id")
  amount     Decimal
  period     BudgetPeriod @default(monthly)
  month      Int?
  year       Int?
  alertAt    Decimal?     @map("alert_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("budgets")
}

model Pocket {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  name       String
  emoji      String?
  color      String?
  amount     Decimal
  month      Int?
  year       Int?
  createdAt  DateTime         @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories PocketCategory[]

  @@map("pockets")
}

model PocketCategory {
  pocketId   String   @map("pocket_id")
  categoryId String   @map("category_id")

  pocket   Pocket   @relation(fields: [pocketId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([pocketId, categoryId])
  @@map("pocket_categories")
}

model Tag {
  id     String @id @default(uuid())
  userId String @map("user_id")
  name   String

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags  ExpenseTag[]

  @@unique([userId, name])
  @@map("tags")
}

model ExpenseTag {
  expenseId String @map("expense_id")
  tagId     String @map("tag_id")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([expenseId, tagId])
  @@map("expense_tags")
}

model SplitBill {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  receiptId     String?           @map("receipt_id")
  merchant      String?
  totalAmount   Decimal           @db.Decimal(12,2) @map("total_amount")
  tax           Decimal           @db.Decimal(12,2) @default(0)
  serviceCharge Decimal           @db.Decimal(12,2) @default(0) @map("service_charge")
  shareCode     String            @unique @map("share_code")
  createdAt     DateTime          @default(now()) @map("created_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  persons       SplitBillPerson[]
  items         SplitBillItem[]

  @@map("split_bills")
}

model SplitBillPerson {
  id          String                 @id @default(uuid())
  splitBillId String                 @map("split_bill_id")
  name        String
  createdAt   DateTime               @default(now()) @map("created_at")

  splitBill   SplitBill              @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  assignments SplitBillAssignment[]

  @@map("split_bill_persons")
}

model SplitBillItem {
  id          String                 @id @default(uuid())
  splitBillId String                 @map("split_bill_id")
  name        String
  price       Decimal                @db.Decimal(12,2)
  quantity    Int                    @default(1)
  createdAt   DateTime               @default(now()) @map("created_at")

  splitBill   SplitBill              @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  assignments SplitBillAssignment[]

  @@map("split_bill_items")
}

model SplitBillAssignment {
  id       String          @id @default(uuid())
  personId String          @map("person_id")
  itemId   String          @map("item_id")
  quantity Int             @default(1)

  person   SplitBillPerson @relation(fields: [personId], references: [id], onDelete: Cascade)
  item     SplitBillItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([personId, itemId])
  @@map("split_bill_assignments")
}
